# Non-secret service settings. ARGUS_ADMIN_TOKEN is inherited from the existing
# root-owned /etc/argus-bridge.env and must never be placed on a command line.
ARGUS_BACKEND_URL=https://argus-backend-3j2m.onrender.com
ARGUS_TICK_TIMEOUT_SECONDS=180
ARGUS_TICK_MAX_ATTEMPTS=2
# GitHub main is the trusted build identity; backend /healthz is observed only.
ARGUS_TRUSTED_BUILD_REF_URL=https://api.github.com/repos/mitsugue/argus/commits/main
ARGUS_BUILD_TRANSITION_GRACE_SECONDS=900
ARGUS_BUILD_IDENTITY_TIMEOUT_SECONDS=15
ARGUS_BUILD_IDENTITY_MAX_ATTEMPTS=2
ARGUS_BUILD_IDENTITY_STATE_FILE=/var/lib/argus-build-identity/state.json
ARGUS_BUILD_IDENTITY_DECISION_FILE=/run/argus-build-identity/decision.json
# Bootstrap-only fallback when GitHub and verified state are both unavailable.
# It is not the normal deployment pin and may be left empty after migration.
ARGUS_EXPECTED_BUILD_SHA=
