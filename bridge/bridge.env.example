# ARGUS moomoo bridge — environment file (copy to /etc/argus-bridge.env, then
# `chmod 600 /etc/argus-bridge.env`). NEVER commit the real file.
ARGUS_BACKEND=https://argus-backend-3j2m.onrender.com
# Same value as the ARGUS_ADMIN_TOKEN in Render (the bridge's push credential):
ARGUS_ADMIN_TOKEN=PUT-YOUR-TOKEN-HERE
# v10.44 HMAC anti-replay: SAME value as Render's ARGUS_BRIDGE_HMAC_SECRET.
# Generate once with: openssl rand -hex 32   (leave empty to push unsigned)
ARGUS_BRIDGE_HMAC_SECRET=
OPEND_HOST=127.0.0.1
OPEND_PORT=11111
# moomoo codes "<MARKET>.<SYMBOL>" — keep in sync with your ARGUS watchlist:
# v10.11+: the 5 JP Layer-1 sensor codes ride along for the Close Pin ledger.
PUSH_SYMBOLS=JP.8058,JP.9984,JP.5801,JP.5803,JP.6584,JP.285A,JP.9501,JP.1306,JP.1321,JP.8306,JP.7203,JP.9432,US.NVDA,US.AAPL,US.TSLA,US.META
PUSH_INTERVAL_SEC=15
# ── v11.5.7 (7/3インシデント対応) ─────────────────────────────────────────
# 口座にJPクォート権限が無い場合のUS-onlyモード。1=JP系を全停止(push/watchlist/
# mover sweep/cap test)。JP権限を取得したらこの行を消してrestart。
# ARGUS_DISABLE_JP_QUOTES=1
# JP権限エラー時の自動バックオフ秒(既定1800=30分)。フラグ無しでもJP失敗はUSを止めない。
# JP_ENTITLEMENT_BACKOFF_SEC=1800
# heartbeat送信間隔(既定60秒・閉場中も送信。バックエンドが生死/権限状態を把握)
# BRIDGE_HEARTBEAT_SEC=60
